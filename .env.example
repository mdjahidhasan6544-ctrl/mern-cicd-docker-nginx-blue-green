# ═══════════════════════════════════════════════════════════════════════════════
#  O Level Stars — Root .env.example
#  Safe to commit. Copy to .env and fill in real values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Backend Runtime ──────────────────────────────────────────────────────────

# Node environment: development | production | test
NODE_ENV=development

# Port the Express server listens on (default: 3001)
PORT=3001
BACKEND_PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?...
# GitHub Secret → MONGO_URI
MONGO_URI=mongodb+srv://<db-user>:<db-password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# ── JSON Web Token ───────────────────────────────────────────────────────────
# Must be a long, random, unpredictable string (min 32 characters).
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# GitHub Secret → JWT_SECRET
JWT_SECRET=<generate-a-strong-random-secret-min-32-chars>

# JWT token lifespan (e.g. 7d, 24h, 3600s)
JWT_EXPIRY=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For production use your real domain(s), e.g. https://www.example.com
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173

# ── Admin Bootstrap Account ──────────────────────────────────────────────────
# Created on first server start if it does not already exist.
# Change the password immediately after first login.
# GitHub Secrets → ADMIN_NAME, ADMIN_EMAIL, ADMIN_PASSWORD
ADMIN_NAME=O Level Stars Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<choose-a-strong-password>

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# Port for the Vite dev server (Docker Compose)
FRONTEND_PORT=5173

# Base URL the frontend uses to reach the backend API.
# In production, set to your deployed backend URL, e.g. https://api.example.com
# GitHub Variable → VITE_API_URL
VITE_API_URL=http://localhost:3001
