# SonarQube Configuration for MERN Stack
# This file is auto-generated by the CI workflow if it does not exist.
# You may also commit a customized version of this file.

sonar.projectKey=mern-app
sonar.projectName=MERN Stack Application
sonar.projectVersion=1.0

# Source directories
sonar.sources=frontend/src,backend/src
sonar.exclusions=**/node_modules/**,**/dist/**,**/build/**,**/coverage/**,**/*.test.js,**/*.spec.js,**/.git/**

# Test and coverage reports
sonar.tests=frontend/src,backend/src
sonar.test.inclusions=**/*.test.js,**/*.test.tsx,**/*.test.ts,**/*.spec.js,**/*.spec.ts
sonar.javascript.lcov.reportPaths=frontend/coverage/lcov.info,backend/coverage/lcov.info

# Encoding
sonar.sourceEncoding=UTF-8

# Server (overridden by GitHub Actions secrets)
# sonar.host.url=https://sonar.example.com
# sonar.login=YOUR_SONAR_TOKEN
