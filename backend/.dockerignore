# ═══════════════════════════════════════════════════════════════════════════════
#  Backend .dockerignore — prevents sensitive / build-irrelevant files
#  from being sent to the Docker daemon or baked into image layers.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Node / npm ──────────────────────────────────────────────────────────────
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.pnpm-store
.yarn

# ── Secrets / env (NEVER bake into images) ──────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks

# ── Build artifacts (rebuilt inside the image) ──────────────────────────────
dist
build
coverage
.nyc_output
*.lcov
test-results

# ── VCS / CI ────────────────────────────────────────────────────────────────
.git
.gitignore
.github
.gitattributes

# ── Local data / DB dumps ──────────────────────────────────────────────────
.mongodb-data
*.sqlite
*.sqlite3
*.db
data
dump
backups

# ── IDE / editor ────────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Logs / temp ─────────────────────────────────────────────────────────────
*.log
logs
tmp
temp
.tmp
.cache

# ── Tests / docs that don't belong in the image ─────────────────────────────
**/*.test.js
**/*.test.mjs
**/*.spec.js
**/*.spec.mjs
**/__tests__/**
**/__mocks__/**
README.md
CLAUDE.md
LICENSE
.eslintrc*
.prettierrc*
.editorconfig
*.md
