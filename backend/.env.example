# ═══════════════════════════════════════════════════════════════════════════════
#  O Level Stars — Backend .env.example
#  Safe to commit. Copy to .env and fill in real values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# MongoDB Atlas connection string.
# GitHub Secret → MONGO_URI
MONGO_URI=mongodb+srv://<db-user>:<db-password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT signing secret — must be long and random (min 32 chars).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# GitHub Secret → JWT_SECRET
JWT_SECRET=<generate-a-strong-random-secret-min-32-chars>

# Token lifespan
JWT_EXPIRY=7d

# Comma-separated allowed frontend origins
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173

# Server port
PORT=3001

# Node environment: development | production
NODE_ENV=development

# Admin bootstrap credentials (auto-created on startup if absent)
# GitHub Secrets → ADMIN_NAME, ADMIN_EMAIL, ADMIN_PASSWORD
ADMIN_NAME=O Level Stars Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<choose-a-strong-password>
